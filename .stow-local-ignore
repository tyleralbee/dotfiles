# Perl regular expressions defining what GNU Stow should NOT create symbolic links for
# https://www.gnu.org/software/stow/manual/html_node/Types-And-Syntax-Of-Ignore-Lists.html

# ======= built-in default ignore list ========

RCS
.+,v

CVS
\.\#.+                    # CVS conflict files / emacs lock files
\.cvsignore

\.svn
_darcs
\.hg

\.git
\.gitignore
\.gitmodules

.+~                       # emacs backup files
\#.*\#                    # emacs autosave files

^/README.*
^/LICENSE.*
^/COPYING

